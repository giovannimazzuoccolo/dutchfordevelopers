// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // NOTE: Prisma CLI currently requires a `url` in the schema even
  // though the canonical connection string lives in prisma.config.ts.
  // This line can simply reference the same env variable.
  url      = env("DATABASE_URL")
}

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  name          String?
  image         String?
  emailVerified DateTime?
  accounts      Account[]
  sessions      Session[]
  scores        Score[]
  // relation added for courses read by the user
  courseUsers   CourseUser[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Game {
  id          String  @id @default(cuid())
  name        String
  description String
  route       String
  fa_icon     String
  scores      Score[]
}

model Score {
  id     String @id @default(cuid())
  gameId String
  score  String
  userId String
  game   Game   @relation(fields: [gameId], references: [id])
  user   User   @relation(fields: [userId], references: [id])
}

// courses and user progress are stored in the database so the frontend
// can fetch them instead of relying on static content.  A join table
// `CourseUser` tracks which users have marked a course as read.
model Course {
  id          String   @id @default(cuid())
  title       String
  description String
  image       String? // can be left blank
  route       String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  courseUsers CourseUser[]
}

model CourseUser {
  id       String @id @default(cuid())
  course   Course @relation(fields: [courseId], references: [id])
  courseId String
  user     User   @relation(fields: [userId], references: [id])
  userId   String

  @@unique([courseId, userId])
}
